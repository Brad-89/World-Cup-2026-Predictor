# Server
PORT=3001
NODE_ENV=development

# Get a free key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_api_key_here

# Password for the admin panel (POST /api/sync, PUT /api/weights, POST /api/matches)
ADMIN_PASSWORD=changeme

# Client (Vite)
# Set to "true" to use built-in mock data instead of hitting the API (no key needed)
VITE_USE_MOCK=true
# Leave blank in dev (Vite proxies /api to localhost:3001 automatically)
VITE_API_URL=
